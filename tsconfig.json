{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@engine/*": ["./src/engine/*"],
      "@ai/*": ["./src/engine/ai/*"],
      "@combat/*": ["./src/engine/combat/*"],
      "@app-types/*": ["./src/types/*"],
      "@constants/*": ["./src/constants/*"],
      "@scripts/*": ["./scripts/*"]
    },

    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts", "eslint.config.mjs"]
}
