{
  "$schema": "https://opencode.ai/config.json",

  // --- MODELOS ---
  // Substitua pelos IDs exatos que você configurou no seu provedor (via /models no TUI)
  /*"model": "qwen/qwen-coder-32b-instruct",*/

  // Modelo mais rápido/barato usado pelo OpenCode para tarefas de background (como resumir diffs)
  /*"small_model": "qwen/qwen-2.5-coder-7b",*/

  // --- COMPORTAMENTO ---
  "autoupdate": true,

  // --- REGRAS DE CONTEXTO ---
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md"
  ],

  // --- SISTEMA DE PERMISSÕES (O MAIS IMPORTANTE) ---
  "permission": {
    // Permite que a IA escreva código, crie arquivos e pesquise pelo repositório livremente
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "bash": "ask",
    "skill": {
      "*": "allow"
    },
    "webfetch": "ask"
  }
}