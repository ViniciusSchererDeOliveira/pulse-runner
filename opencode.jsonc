{
  "$schema": "https://opencode.ai/config.json",

  // --- COMPORTAMENTO ---
  "autoupdate": true,

  // --- REGRAS DE CONTEXTO ---
  // Ao usar Glob Patterns, você obriga a IA a ler tudo isso ANTES do primeiro "Hello".
  "instructions": [
    "AGENTS.md",
    "CONTRIBUTING.md",
    // Lê todos os SKILL.md dentro das subpastas de skills
    ".opencode/skills/**/*.md",
    // (Opcional) Lê qualquer outro .md na raiz do projeto
    "*.md"
  ],

  // --- SISTEMA DE PERMISSÕES (O MAIS IMPORTANTE) ---
  "permission": {
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "bash": "ask",
    "skill": {
      "*": "allow"
    },
    "webfetch": "ask"
  }
}